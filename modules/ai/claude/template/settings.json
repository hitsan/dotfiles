{
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl http://127.0.0.1:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog|agent_needs_input",
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/hitsan/.config/zellij/scripts/claude-tab-status.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /home/hitsan/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "ppt-creator@daymade-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "draw-io@claude-drawio-skill": true
  },
  "extraKnownMarketplaces": {
    "claude-drawio-skill": {
      "source": {
        "source": "github",
        "repo": "little-hands/claude-drawio-skill"
      }
    },
    "claude-code-zellij-status": {
      "source": {
        "source": "git",
        "url": "https://github.com/thoo/claude-code-zellij-status.git"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "high",
  "tui": "fullscreen"
}
