layout {
    pane size=1 borderless=true {
        plugin location="compact-bar" {
            format_left  "{tabs}"
            format_center ""
            format_right "{mode}"
            format_space "#[bg=#2e3440]"

            mode_normal  "#[fg=#88c0d0,bg=#2e3440]#[fg=#2e3440,bg=#88c0d0,bold] NORMAL #[fg=#88c0d0,bg=#2e3440]"
            mode_locked  "#[fg=#bf616a,bg=#2e3440]#[fg=#2e3440,bg=#bf616a,bold] g Unlock #[fg=#bf616a,bg=#2e3440]"
            mode_pane    "#[fg=#81a1c1,bg=#2e3440]#[fg=#2e3440,bg=#81a1c1,bold] h/j/k/l Move  n New  d Down  r Right  s Stack  w Float  f Full  e Embed  c Rename  i Pin  z Frame  x Close #[fg=#81a1c1,bg=#2e3440]"
            mode_tab     "#[fg=#5e81ac,bg=#2e3440]#[fg=#2e3440,bg=#5e81ac,bold] h/j/k/l Switch  1-9 Go  n New  x Close  r Rename  s Sync  b Break  [/] BreakL/R #[fg=#5e81ac,bg=#2e3440]"
            mode_resize  "#[fg=#8fbcbb,bg=#2e3440]#[fg=#2e3440,bg=#8fbcbb,bold] h/j/k/l Inc  H/J/K/L Dec  +/- Inc/Dec #[fg=#8fbcbb,bg=#2e3440]"
            mode_move    "#[fg=#b48ead,bg=#2e3440]#[fg=#2e3440,bg=#b48ead,bold] h/j/k/l Move  n Next  p Prev #[fg=#b48ead,bg=#2e3440]"
            mode_scroll  "#[fg=#d08770,bg=#2e3440]#[fg=#2e3440,bg=#d08770,bold] j/k Scroll  d/u HalfPage  f/b Page  e Edit  s Search #[fg=#d08770,bg=#2e3440]"
            mode_session "#[fg=#88c0d0,bg=#2e3440]#[fg=#2e3440,bg=#88c0d0,bold] d Detach  a About  c Config  p Plugins  w Sessions  s Share  l Layouts #[fg=#88c0d0,bg=#2e3440]"
            mode_search  "#[fg=#bf616a,bg=#2e3440]#[fg=#2e3440,bg=#bf616a,bold] n/p Next/Prev  c Case  o Word  w Wrap #[fg=#bf616a,bg=#2e3440]"
            // mode_tmux is repurposed as the keybind hint display (Ctrl+k); unrelated to tmux itself
            mode_tmux    "#[fg=#b48ead,bg=#2e3440]#[fg=#2e3440,bg=#b48ead,bold] g Lock  p Pane  t Tab  n Resize  h Move  s Scroll  o Session  q Quit #[fg=#b48ead,bg=#2e3440]"

            tab_normal   "#[fg=#2e3440,bg=#3b4252]#[fg=#d8dee9,bg=#3b4252] {name}{fullscreen_indicator} #[fg=#3b4252,bg=#2e3440]"
            tab_active   "#[fg=#2e3440,bg=#88c0d0,bold]#[fg=#2e3440,bg=#88c0d0,bold] {name}{fullscreen_indicator} #[fg=#88c0d0,bg=#2e3440]"

            tab_fullscreen_indicator " ⛶"
        }
    }
    pane
}
